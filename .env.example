# Groq API Key - Obtenha gratuitamente em https://console.groq.com
# O Tutor de IA só funcionará com uma chave válida
# O resto da plataforma funciona normalmente sem ela
GROQ_API_KEY=your_groq_api_key_here

# Supabase - Obtenha em https://supabase.com
# Necessário para autenticação e banco de dados
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
